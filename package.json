{
  "name": "impview",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "lint": "eslint . && stylelint \"src/**/*.scss\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,html}": "eslint --fix",
    "*.scss": "stylelint --fix",
    "*.{js,html,scss,json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.59.0",
    "@html-eslint/parser": "^0.59.0",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sass": "^1.86.3",
    "stylelint": "^17.8.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^5.4.19"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "vite-plugin-pwa": "^1.2.0"
  }
}
